# Salin file ini menjadi .env.local dan isi nilainya. JANGAN commit .env.local
# (sudah di-ignore lewat .gitignore).

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Web Push (notifikasi browser) ---
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# --- Sentry (error monitoring, tier gratis) ---
# DSN diambil dari Sentry > Project Settings > Client Keys (DSN). https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=

# Opsional, hanya dibutuhkan saat build di CI/Vercel untuk upload source maps ke Sentry.
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
